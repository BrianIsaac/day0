# Day0 — environment contract
# Copy to .env.local and fill in real values.
# This file grows phase by phase. Each phase only adds the keys it needs.

# --- Clerk (per-user auth so each visitor has their own demo) ---
# https://dashboard.clerk.com/last-active?path=api-keys
# Keyless dev mode auto-provisions temporary keys on the client when these are
# blank, so `pnpm dev` works without filling them in. Real values are required
# for server-side `auth.protect()` and JWT verification.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/
