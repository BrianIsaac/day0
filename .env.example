# Day0 — environment contract
# Copy to .env.local and fill in real values.

# --- Convex (DB + actions + scheduler) ---
# Run `pnpm convex:dev` once to create the deployment; values get written automatically.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Clerk (per-user auth so each visitor has their own demo) ---
# https://dashboard.clerk.com/last-active?path=api-keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# In Clerk dashboard: JWT Templates -> New template -> name: "convex".
# Copy the "Issuer" URL (no trailing slash) into the value below + into Convex env:
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN <url>
CLERK_JWT_ISSUER_DOMAIN=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- OpenAI (charter synthesis, plan-draft, executor, skill author) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2

# --- ElevenLabs (primary voice path for Day-1 1:1) ---
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Create a Conversational AI agent in the dashboard and paste its id here
ELEVENLABS_AGENT_ID=

# --- Google Gemini (fallback voice path; gen-media if needed) ---
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_LIVE_MODEL=gemini-flash-3.1-live

# --- Exa (web research for good-habits memory) ---
# https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# --- Daytona (sandbox for autonomous skill authoring) ---
# https://app.daytona.io/dashboard/keys
DAYTONA_API_KEY=
DAYTONA_API_URL=https://app.daytona.io/api

# --- Demo defaults ---
# The boss email pre-filled on the deploy form (you, the demo operator).
NEXT_PUBLIC_DEMO_BOSS_EMAIL=
# A short tenant slug for the demo company (used as a key prefix in Convex).
NEXT_PUBLIC_DEMO_TENANT_SLUG=acme-demo
